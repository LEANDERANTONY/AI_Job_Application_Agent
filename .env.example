## Optional for AI-assisted workflow and assistant features.
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5-mini-2025-08-07
OPENAI_MODEL_HIGH_TRUST=gpt-5.4
OPENAI_MODEL_MID_TIER=gpt-5-mini-2025-08-07
OPENAI_MODEL_PRODUCT_HELP=gpt-5-mini-2025-08-07
OPENAI_MODEL_APPLICATION_QA=gpt-5.4

## Optional app base URL. Used as the default auth redirect URL when no
## explicit SUPABASE_AUTH_REDIRECT_URL is provided.
APP_BASE_URL=http://localhost:8501

## Optional browser-session limits for the assisted workflow.
OPENAI_MAX_CALLS_PER_SESSION=24
OPENAI_MAX_TOKENS_PER_SESSION=120000

## Optional for a deploy without Supabase. Required only when you want
## Google sign-in, persisted history, and account-level quotas.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_REDIRECT_URL=http://localhost:8501
SUPABASE_APP_USERS_TABLE=app_users
SUPABASE_USAGE_EVENTS_TABLE=usage_events
SUPABASE_WORKFLOW_RUNS_TABLE=workflow_runs
SUPABASE_ARTIFACTS_TABLE=artifacts

## Default local behavior before Supabase is provisioned. Keep this false if
## you want the assisted workflow button available without login on an early deploy.
AUTH_REQUIRED_FOR_ASSISTED_WORKFLOW=true
AUTH_DEFAULT_PLAN_TIER=free
AUTH_DEFAULT_ACCOUNT_STATUS=active
FREE_TIER_MAX_CALLS_PER_DAY=12
FREE_TIER_MAX_TOKENS_PER_DAY=60000
PAID_TIER_MAX_CALLS_PER_DAY=80
PAID_TIER_MAX_TOKENS_PER_DAY=400000

