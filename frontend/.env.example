# Local development keeps the frontend calling the backend through a same-origin rewrite.
NEXT_PUBLIC_API_BASE_URL=/api
API_REWRITE_TARGET=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production example once the FastAPI backend is on the VPS:
# NEXT_PUBLIC_API_BASE_URL=/api
# API_REWRITE_TARGET=https://api.example.com
# NEXT_PUBLIC_SITE_URL=https://app.example.com

# Observability — Sentry (jobagent-frontend project) + PostHog
# (Job Application Agent project). NEXT_PUBLIC_ prefix inlines these
# values into the JS bundle at build time. Leave empty for local dev
# without analytics — the SDK init paths are no-ops on empty values.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Source-map upload at build time. Vercel's Sentry integration auto-
# provisions this; manual setup needs project:releases + project:read.
SENTRY_AUTH_TOKEN=
